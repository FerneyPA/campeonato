# JNDI — producción
jndi.campeonato=java:comp/env/jdbc/campeonatoDB

# DriverManager — tests y diagnóstico
driver.campeonato.url=jdbc:mysql://localhost:3306/campeonatoDB
driver.campeonato.usuario=
driver.campeonato.clave=
