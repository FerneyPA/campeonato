# JNDI — producción
jndi.seguridad=java:comp/env/jdbc/seguridadDB

# DriverManager — tests y diagnóstico
driver.seguridad.url=jdbc:mysql://localhost:3306/seguridadDB
driver.seguridad.usuario=
driver.seguridad.clave=
