# JNDI — producción
jndi.estadisticas=java:comp/env/jdbc/estadisticasDB

# DriverManager — tests y diagnóstico
driver.estadisticas.url=jdbc:mysql://localhost:3306/estadisticasDB
driver.estadisticas.usuario=
driver.estadisticas.clave=
